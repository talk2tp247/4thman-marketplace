'use client'

import { useState } from 'react'
import { Plus, X, ArrowLeft, Check } from 'lucide-react'
import Link from 'next/link'

export default function AddProductPage() {
  const [productType, setProductType] = useState<'digital' | 'physical'>('digital')
  const [formData, setFormData] = useState({ title: '', description: '', category: '', price: '', comparePrice: '', tags: '' })
  const [isPublished, setIsPublished] = useState(false)

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault()
    setIsPublished(true)
    setTimeout(() => setIsPublished(false), 3000)
  }

  if (isPublished) {
    return (
      <div className="min-h-screen bg-surface dark:bg-gray-900 flex items-center justify-center px-4">
        <div className="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-8 max-w-md w-full text-center">
          <div className="w-20 h-20 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-6"><Check size={40} className="text-green-600 dark:text-green-400" /></div>
          <h2 className="text-2xl font-bold text-gray-900 dark:text-white mb-2">Product Published! 🎉</h2>
          <p className="text-gray-500 dark:text-gray-400 mb-6">Your product is now live on 4thMan</p>
          <div className="flex gap-3 justify-center"><Link href="/dashboard/seller" className="btn-primary">Back to Dashboard</Link><Link href="/products" className="px-6 py-3 border border-gray-200 dark:border-gray-700 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">View Product</Link></div>
        </div>
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-surface dark:bg-gray-900">
      <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div className="flex items-center gap-3 mb-8"><Link href="/dashboard/seller" className="text-gray-400 hover:text-gray-600"><ArrowLeft size={20} /></Link><Plus size={20} className="text-brand-gold" /><h1 className="text-2xl font-bold text-gray-900 dark:text-white">Add New Product</h1></div>
        <form onSubmit={handleSubmit}>
          <div className="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 space-y-4">
            <div><label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Product Title</label><input type="text" value={formData.title} onChange={(e) => setFormData({...formData, title: e.target.value})} placeholder="e.g., Ultimate Web Development Course" className="input-field" required /></div>
            <div><label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label><textarea value={formData.description} onChange={(e) => setFormData({...formData, description: e.target.value})} placeholder="Describe your product in detail..." rows={5} className="input-field resize-none" required /></div>
            <div className="grid sm:grid-cols-2 gap-4">
              <div><label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Category</label><select value={formData.category} onChange={(e) => setFormData({...formData, category: e.target.value})} className="input-field" required><option value="">Select category</option><option value="eBooks">eBooks</option><option value="Software">Software</option><option value="Online Courses">Online Courses</option><option value="Templates">Templates</option></select></div>
              <div><label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Product Type</label><div className="grid grid-cols-2 gap-2"><button type="button" onClick={() => setProductType('digital')} className={`py-2.5 rounded-lg text-sm font-medium border transition-colors ${productType === 'digital' ? 'border-brand-blue bg-blue-50 dark:bg-blue-900/30 text-brand-blue' : 'border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400'}`}>Digital</button><button type="button" onClick={() => setProductType('physical')} className={`py-2.5 rounded-lg text-sm font-medium border transition-colors ${productType === 'physical' ? 'border-brand-blue bg-blue-50 dark:bg-blue-900/30 text-brand-blue' : 'border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400'}`}>Physical</button></div></div>
            </div>
            <div className="grid sm:grid-cols-2 gap-4">
              <div><label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Price ($)</label><input type="number" value={formData.price} onChange={(e) => setFormData({...formData, price: e.target.value})} placeholder="29.99" step="0.01" min="0" className="input-field" required /></div>
              <div><label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Compare Price ($)</label><input type="number" value={formData.comparePrice} onChange={(e) => setFormData({...formData, comparePrice: e.target.value})} placeholder="49.99" step="0.01" min="0" className="input-field" /></div>
            </div>
            <button type="submit" className="btn-primary w-full">Publish Product</button>
          </div>
        </form>
      </div>
    </div>
  )
}
