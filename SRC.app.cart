'use client'

import { useState } from 'react'
import { Bell, Package, Star, MessageCircle, Truck, DollarSign, X } from 'lucide-react'
import Link from 'next/link'

const allNotifications = [
  { id: 1, type: 'order', title: 'New Order Received', description: 'John Doe ordered "Ultimate Web Dev Course" - $49.99', time: '2 min ago', read: false },
  { id: 2, type: 'payment', title: 'Payment Confirmed', description: 'Payment of $49.99 has been confirmed.', time: '5 min ago', read: false },
  { id: 3, type: 'review', title: 'New 5-Star Review', description: 'Alice M. left a 5-star review.', time: '1 hour ago', read: false },
  { id: 4, type: 'shipping', title: 'Order Shipped', description: '#ORD-4519 has been shipped.', time: '3 hours ago', read: true },
  { id: 5, type: 'message', title: 'New Message', description: 'Sarah Smith sent a message.', time: '5 hours ago', read: true },
  { id: 6, type: 'system', title: 'Weekly Report Ready', description: 'Your sales report is available.', time: '1 day ago', read: true },
  { id: 7, type: 'payment', title: 'Payout Processed', description: '$1,247.50 sent to your bank.', time: '3 days ago', read: true },
]

const typeIcons: Record<string, React.ElementType> = { order: Package, review: Star, message: MessageCircle, shipping: Truck, payment: DollarSign, system: Bell }
const typeColors: Record<string, string> = {
  order: 'text-brand-blue bg-blue-100 dark:bg-blue-900/30', review: 'text-brand-gold bg-amber-100 dark:bg-amber-900/30',
  message: 'text-purple-600 bg-purple-100 dark:bg-purple-900/30', shipping: 'text-green-600 bg-green-100 dark:bg-green-900/30',
  payment: 'text-green-600 bg-green-100 dark:bg-green-900/30', system: 'text-gray-600 bg-gray-100 dark:bg-gray-700',
}

export default function NotificationsPage() {
  const [notifications, setNotifications] = useState(allNotifications)
  const [filter, setFilter] = useState<'all' | 'unread'>('all')
  const filtered = filter === 'all' ? notifications : notifications.filter(n => !n.read)
  const markAllRead = () => setNotifications(prev => prev.map(n => ({ ...n, read: true })))
  const removeNotif = (id: number) => setNotifications(prev => prev.filter(n => n.id !== id))

  return (
    <div className="min-h-screen bg-surface dark:bg-gray-900">
      <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div className="flex items-center justify-between mb-6">
          <div><h1 className="text-2xl font-bold text-gray-900 dark:text-white">Notifications</h1><p className="text-sm text-gray-500 dark:text-gray-400 mt-1">{notifications.filter(n => !n.read).length} unread</p></div>
          <div className="flex gap-2">
            <button onClick={() => setFilter(filter === 'all' ? 'unread' : 'all')} className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${filter === 'all' ? 'bg-brand-blue text-white' : 'bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700'}`}>{filter === 'all' ? 'All' : 'Unread'}</button>
            <button onClick={markAllRead} className="px-4 py-2 text-sm font-medium text-brand-blue hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg border border-gray-200 dark:border-gray-700">Mark All Read</button>
          </div>
        </div>
        <div className="space-y-2">
          {filtered.map(notif => {
            const Icon = typeIcons[notif.type]
            return (
              <div key={notif.id} className={`bg-white dark:bg-gray-800 rounded-xl p-4 flex items-start gap-4 shadow-sm transition-colors ${!notif.read ? 'border-l-4 border-brand-blue' : ''}`}>
                <div className={`w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 ${typeColors[notif.type]}`}><Icon size={18} /></div>
                <div className="flex-1 min-w-0">
                  <div className="flex items-start justify-between">
                    <div><p className="font-medium text-gray-900 dark:text-white">{notif.title}</p><p className="text-sm text-gray-500 dark:text-gray-400 mt-0.5">{notif.description}</p></div>
                    <button onClick={() => removeNotif(notif.id)} className="text-gray-400 hover:text-gray-600 ml-4 flex-shrink-0"><X size={16} /></button>
                  </div>
                  <p className="text-xs text-gray-400 dark:text-gray-500 mt-2">{notif.time}</p>
                </div>
              </div>
            )
          })}
          {filtered.length === 0 && <div className="text-center py-20"><Bell size={48} className="mx-auto text-gray-300 dark:text-gray-600 mb-4" /><h3 className="text-lg font-semibold text-gray-900 dark:text-white">No notifications</h3></div>}
        </div>
      </div>
    </div>
  )
}
