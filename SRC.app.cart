  { id: '#ORD-4520', customer: 'Sarah Smith', items: 'Business Pro Template Pack', amount: 29.99, date: 'Mar 17, 2024', status: 'Processing' as const },
  { id: '#ORD-4519', customer: 'Mike Johnson', items: 'Premium Photo Editing Software', amount: 89.99, date: 'Mar 16, 2024', status: 'Shipped' as const },
  { id: '#ORD-4518', customer: 'Emily Davis', items: 'Digital Marketing eBook', amount: 19.99, date: 'Mar 15, 2024', status: 'Delivered' as const },
